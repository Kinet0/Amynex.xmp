{
  "manifest_version": 3,
  "name": "PhishGuard v1",
  "version": "1.0",
  "description": "Real-time phishing detection for Chrome using URL and page content analysis.",
  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "PhishGuard v1"
  },
  "background": {
    "service_worker": "content/content.js"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
