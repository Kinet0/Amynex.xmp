{
  "manifest_version": 3,
  "name": "Amynex.xmp",
  "version": "3.0",
  "description": "Amynex.xmp delivers advanced local phishing detection, URL intelligence, DOM inspection, reputation analysis, and reporting.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "notifications"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Amynex.xmp"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
