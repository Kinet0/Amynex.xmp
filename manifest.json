{
  "manifest_version": 3,
  "name": "PhishGuard v2",
  "version": "2.0",
  "description": "Advanced phishing detection for Chrome with URL, DOM, threat intelligence, and reporting.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "notifications"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "PhishGuard v2"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
